---
const particles = [
  { emoji: '🍰', left: 8,  delay: 0,   dur: 7   },
  { emoji: '✨', left: 20, delay: 1.2, dur: 5.5 },
  { emoji: '🎂', left: 35, delay: 0.5, dur: 8   },
  { emoji: '🌸', left: 52, delay: 2,   dur: 6   },
  { emoji: '⭐', left: 65, delay: 0.8, dur: 7.5 },
  { emoji: '🍓', left: 78, delay: 1.6, dur: 6.5 },
  { emoji: '✨', left: 90, delay: 3,   dur: 5   },
  { emoji: '🌸', left: 44, delay: 2.5, dur: 9   },
];
---

<section class="hero">
  <div class="particles" aria-hidden="true">
    {particles.map(p => (
      <span
        class="particle"
        style={`left:${p.left}%; animation-delay:${p.delay}s; animation-duration:${p.dur}s;`}
      >{p.emoji}</span>
    ))}
  </div>

  <div class="hero-left reveal-child">
    <span class="eyebrow">✦ Pasūti savu sapņu kūku</span>
    <h1>Mājās ceptas kūkas <em>ar mīlestību</em></h1>
    <p>Pašmāju konditorejas izstrādājumi katrai īpašai reizei.</p>
    <div class="hero-btns">
      <a href="#izvēlne" class="btn-filled">Skatīt izvēlni</a>
      <a href="#par-mani" class="btn-outline">Par mani</a>
    </div>
  </div>

  <div class="hero-right reveal-child" style="animation-delay:.25s">
    <div class="hero-img-wrap">
      <img src="/hero.jpg" alt="Kūciņš kūka" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 90vh;
    padding: 60px 5%;
    gap: 48px;
    background: var(--cream);
    overflow: hidden;
  }

  /* ── floating particles ── */
  .particles { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .particle {
    position: absolute;
    bottom: -60px;
    font-size: 1.6rem;
    opacity: 0;
    animation: floatUp linear infinite;
  }
  @keyframes floatUp {
    0%   { transform: translateY(0)     rotate(0deg);   opacity: 0;   }
    8%   { opacity: .55; }
    85%  { opacity: .3; }
    100% { transform: translateY(-100vh) rotate(25deg); opacity: 0;   }
  }

  /* ── entrance animations ── */
  .reveal-child {
    opacity: 0;
    transform: translateY(28px);
    animation: fadeUp .8s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: none; }
  }

  .hero-left  { position: relative; z-index: 1; flex: 1; max-width: 50%; display: flex; flex-direction: column; gap: 1.5rem; }
  .hero-right { position: relative; z-index: 1; flex: 1; max-width: 50%; display: flex; justify-content: center; }

  .eyebrow {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--green);
  }

  /* ── shimmer h1 ── */
  h1 {
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
  }
  h1 em {
    font-style: normal;
    background: linear-gradient(90deg, #860120 0%, #d4244e 35%, #ff6b8a 55%, #d4244e 75%, #860120 100%);
    background-size: 250% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }
  @keyframes shimmer {
    0%   { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  .hero-left p {
    font-size: 1.125rem;
    color: #555;
    line-height: 1.6;
    max-width: 480px;
  }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ── bobbing image ── */
  .hero-img-wrap {
    width: 100%;
    aspect-ratio: 4/5;
    max-height: 580px;
    border-radius: 28px;
    border: 4px solid var(--pink);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(134,1,32,.15);
    animation: bob 5s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }
  .hero-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 768px) {
    .hero        { flex-direction: column; min-height: auto; padding: 40px 5% 48px; }
    .hero-left   { max-width: 100%; }
    .hero-right  { display: none; }
    .hero-btns a { width: 100%; text-align: center; }
  }
</style>
