<style>
  .cta {
    background: var(--accent);
    padding: 80px 5%;
    text-align: center;
  }
  .cta h2 { font-size: 2.5rem; color: #fff; margin-bottom: 1rem; }
  .cta p  { font-size: 1.0625rem; color: rgba(255,255,255,.85); margin-bottom: 2.25rem; max-width: 480px; margin-left: auto; margin-right: auto; }

  .btn-white {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .875rem 2.5rem;
    border-radius: 2rem;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: .03em;
    background: #fff;
    color: var(--accent);
    border: none;
    box-shadow: 0 6px 24px rgba(0,0,0,.2), inset 0 1px 0 rgba(255,255,255,.9);
    transition: transform .18s, box-shadow .18s, background .2s;
  }
  .btn-white::after { content: '→'; transition: transform .2s; }
  .btn-white:hover {
    transform: translateY(-3px);
    background: var(--pink);
    box-shadow: 0 12px 32px rgba(0,0,0,.28);
  }
  .btn-white:hover::after { transform: translateX(4px); }

  .socials {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: .5rem;
    color: rgba(255,255,255,.85);
    font-size: .875rem;
    font-weight: 500;
    transition: color .2s;
  }
  .social-link:hover { color: #fff; }
</style>
